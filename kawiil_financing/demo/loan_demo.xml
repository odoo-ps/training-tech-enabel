        <record id="loan_demo_1" model="loan.application">
            <field name="name">LOAN-001</field>
            <field name="partner_id" ref="base.res_partner_1"/>
            <field name="loan_amount">5000000</field>
            <field name="interest_rate">5.5</field>
            <field name="date_applied">2024-01-01</field>
        </record>

        <record id="loan_demo_2" model="loan.application">
            <field name="name">LOAN-002</field>
