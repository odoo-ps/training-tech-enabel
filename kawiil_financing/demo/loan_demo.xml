            <field name="interest_rate">4.2</field>
            <field name="date_applied"
                   eval="(fields.Date.today() - relativedelta(months=5))"/>
        </record>

        <record id="loan_demo_3" model="loan.application">
            <field name="name">LOAN-003</field>
            <field name="partner_id" ref="base.res_partner_3"/>
