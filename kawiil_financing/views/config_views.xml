<?xml version="1.0"?>
<odoo>

    <!-- TAGS -->
    <record id="view_tag_list" model="ir.ui.view">
        <field name="model">loan.application.tag</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="color"/>
            </list>
        </field>
    </record>

    <record id="action_tags" model="ir.actions.act_window">
        <field name="name">Tags</field>
        <field name="res_model">loan.application.tag</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- DOC TYPE -->
    <record id="view_doc_type_list" model="ir.ui.view">
        <field name="model">loan.application.document.type</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="is_required"/>
            </list>
        </field>
    </record>

    <record id="action_doc_types" model="ir.actions.act_window">
        <field name="name">Types de documents</field>
        <field name="res_model">loan.application.document.type</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
