<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="module_category_dealership" model="ir.module.category">
            <field name="name">Dealership</field>
        </record>

        <record id="privilege_financing" model="res.groups.privilege">
            <field name="name">Financing</field>
            <field name="category_id" ref="module_category_dealership"/>
        </record>

        <record id="group_loan_application_user" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="privilege_financing"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_loan_application_admin" model="res.groups">
            <field name="name">Admin</field>
            <field name="privilege_id" ref="privilege_financing"/>
            <field name="implied_ids" eval="[(4, ref('group_loan_application_user'))]"/>
        </record>
    </data>
</odoo>
